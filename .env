# All bridges
CONF_bridges=ZigBee,HTTP,Bluetooth,LoRa,Thread
CONF_bridgesWaitShutdownSeconds=5

# Ports for the server, broker and bridges
CONF_baseURL=http://localhost
CONF_portBroker=9999
CONF_portServer=9998
CONF_portBridgeZigBee=9997
CONF_portBridgeHTTP=9996
CONF_portBridgeBluetooth=9995
CONF_portBridgeLoRa=9994
CONF_portBridgeThread=9993
CONF_portHealthcheck=9990

# Database
CONF_databaseFilename=../healthcore_database.db

# Healthcheck
CONF_dashboardRefreshIntervalMs=30000
CONF_dashboardRecentInsightsCount=3
CONF_dashboardRecentNotificationsCount=3

# MQTT broker address and credentials
CONF_brokerAddress=mqtt://localhost:9999
CONF_brokerUsername=
CONF_brokerPassword=

# Allowed CORS URLs for API requests (comma-separated, e.g. http://localhost:3001,capacitor://localhost)
CONF_corsURL=

# Server ID
CONF_serverID=bulp.io
CONF_serverVersion=0.1
CONF_serverIDBonjour=healthcore

# Settings for LoRa adapter
CONF_loRaAdapterPath=
CONF_loRaAdapterBaudRate=9600
CONF_loRaAdapterFRE=868.700,868.700
CONF_loRaAdapterSF=12,12
CONF_loRaAdapterBW=0,0
CONF_loRaAdapterPOWER=14
CONF_loRaAdapterCRC=1,1
CONF_loRaAdapterRXMOD=65535,0
CONF_loRaAdapterReconnectIntervalSeconds=20

# Settings for ZigBee adapter
CONF_zigBeeAdapterPort=
CONF_zigBeeAdapterName=
CONF_zigBeeReportingTimeout=5000

# List of database tables allowed for API access
CONF_tablesAllowedForAPI=individuals,rooms,users,sos,settings,push_tokens,notifications,care_insight_rules
CONF_tablesMaxEntriesReturned=500 

# API calls
CONF_apiCallTimeoutMilliseconds=10000

# Devices
CONF_scanTimeDefaultSeconds=30
CONF_scenarioCooldownMilliseconds=5000

CONF_devicesBluetoothMaintenanceIntervalSeconds=60 # Interval in seconds for performing maintenance tasks on Bluetooth devices, such as checking their status and reconnecting if necessary
CONF_devicesBluetoothMaintenanceScanDurationSeconds=10 # Duration in seconds for performing a Bluetooth scan during maintenance tasks
CONF_devicesBluetoothWatchdogTimeoutSeconds=300  # Time in seconds after which a Bluetooth device is considered unresponsive if no communication is received
CONF_devicesBluetoothBatteryThresholdPercent=15
CONF_devicesBluetoothBatteryAlertCooldownHours=1

CONF_devicesZigBeeMaintenanceIntervalSeconds=60 # Interval in seconds for performing maintenance tasks on ZigBee devices, such as checking their status and reconnecting if necessary
CONF_devicesZigBeeAdapterReconnectBaseDelaySeconds=5 # Initial delay before reconnecting the ZigBee adapter; doubles each attempt (5s → 10s → 20s → …) via exponential backoff
CONF_devicesZigBeeAdapterReconnectMaxDelaySeconds=300 # Cap for the exponential backoff above; reconnect attempts will never wait longer than this
CONF_devicesZigBeeWatchdogTimeoutSeconds=3600 # Time a connected device may be silent before an alert is sent; intentionally >> ReconnectMaxDelay to avoid false alarms during adapter outages
CONF_devicesZigBeeBatteryThresholdPercent=15
CONF_devicesZigBeeBatteryAlertCooldownHours=1

# API Key for authentication (send as header 'x-api-key')
CONF_apiKey=

# TLS/HTTPS (leave empty to use HTTP)
CONF_tlsPath=../../
CONF_tlsRejectUnauthorized=false

# Path to Firebase service account key file (keep this file outside the repository!)
CONF_pushFirebaseKeyPath=../../../

# Care Insights
CONF_careInsightsActive=true
CONF_careInsightsAnomalyThreshold=0.6
CONF_careInsightsHistorySize=200
CONF_careInsightsMinHistoryEntries=10
CONF_careInsightsMaxSignalsPerInsight=50
CONF_careInsightsLanguage=de
